{
  "expo": {
    "name": "AbsherMetrics",
    "slug": "abshermetrics",
    "version": "1.0.2",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "abshermetrics",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.abshermetrics.app",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.abshermetrics.app",
      "adaptiveIcon": {
        "backgroundColor": "#d4ff4f",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#070d0a",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 150,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#d4ff4f"
        }
      ],
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsFileWithMaxCount": 1
          },
          "androidIntentFilters": [
            "text/csv",
            "text/comma-separated-values",
            "application/csv",
            "text/plain",
            "application/octet-stream"
          ]
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.244470461095-q8onrduod8afkbkbvvhonuhvdfoeustu"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9cc29243-958f-4474-9ff5-50222a2679bf"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9cc29243-958f-4474-9ff5-50222a2679bf"
    }
  }
}
