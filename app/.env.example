# Copy this file to app/.env and fill in your Supabase project values.
# Find them in the Supabase dashboard → Project Settings → API.
# These EXPO_PUBLIC_* vars are inlined at bundle time; the anon key is safe to ship
# (Row-Level Security protects the data). Restart Metro after editing.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
